{
  "name": "joinup-travel",
  "version": "1.0.0",
  "private": true,
  "description": "JoinUp Travel - Never Travel Alone",
  "scripts": {
    "build": "pnpm --filter=web run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter backend prisma generate",
    "db:migrate": "pnpm --filter backend prisma migrate dev",
    "db:push": "pnpm --filter backend prisma db push",
    "db:studio": "pnpm --filter backend prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
